{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Azure Functions Doctor Rules Schema",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id", "category", "section", "label",
      "description", "type", "required",
      "condition", "check_order"
    ],
    "properties": {
      "id": {
        "type": "string",
        "description": "Unique identifier for the rule."
      },
      "category": {
        "type": "string",
        "description": "Top-level grouping category.",
        "enum": [
          "environment",
          "dependencies",
          "structure",
          "project_structure",
          "configuration",
          "bindings",
          "tooling",
          "telemetry",
          "framework",
          "project_health",
          "config",
          "tools"
        ]
      },
      "section": {
        "type": "string",
        "description": "Section used to group checks in output (e.g., python_env)."
      },
      "label": {
        "type": "string",
        "description": "Label displayed in CLI output."
      },
      "description": {
        "type": "string",
        "description": "Description of what this rule checks."
      },
      "type": {
        "type": "string",
        "description": "Handler type used to execute the check.",
        "enum": [
          "compare_version",
          "file_exists",
          "env_var_exists",
          "package_installed",
          "package_declared",
          "path_exists",
          "source_code_contains",
          "conditional_exists",
          "callable_detection",
          "executable_exists",
          "any_of_exists",
          "file_glob_check",
          "host_json_property",
          "host_json_version",
          "local_settings_security",
          "host_json_extension_bundle_version"
        ]
      },
      "required": {
        "type": "boolean",
        "description": "Whether this check is required to pass."
      },
      
      "condition": {
        "type": "object",
        "description": "Condition parameters used by the handler.",
        "properties": {
          "target": { "type": "string" },
          "operator": { "type": "string" },
          "value": {},
          "keyword": { "type": "string" },
          "pypi": { "type": "string" },
          "package": { "type": "string" },
          "file": { "type": "string" },
          "jsonpath": { "type": "string" },
          "targets": { "type": "array", "items": { "type": "string" } },
          "patterns": { "type": "array", "items": { "type": "string" } },
          "mode": { "type": "string", "enum": ["string", "ast"], "description": "For source_code_contains: 'string' (default) or 'ast' for AST-based detection." }
        }
      },
      "hint": {
        "type": "string",
        "description": "Hint message shown to users on failure."
      },
      "severity": {
        "type": "string",
        "description": "Severity classification for the rule (optional)."
      },
      "fix": {
        "type": "string",
        "description": "Natural language fix instruction (optional)."
      },
      "fix_command": {
        "type": "string",
        "description": "CLI command to fix the issue (optional)."
      },
      "hint_url": {
        "type": "string",
        "description": "URL for documentation or solution (optional).",
        "format": "uri"
      },
      "tags": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Searchable tags or keywords (optional)."
      },
      "impact": {
        "type": "string",
        "description": "Effect of failure if not resolved (optional)."
      },
      "check_order": {
        "type": "integer",
        "description": "Display and execution order of the check.",
        "minimum": 0
      }
    },
    "additionalProperties": false
  }
}
